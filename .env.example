# Copia este archivo a .env y ajusta si lo necesitas.
# Estos mismos valores son los que usa DatabaseConfig como default si no
# hay variables de entorno exportadas, así que "docker compose up" + correr
# la app funcionan sin pasos adicionales.

# Postgres (leído por docker-compose.yml)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pokemon_db
DB_USER=pokemon_user
DB_PASSWORD=pokemon_pass

# Para Java (leído por DatabaseConfig)
# Si Java corre en el host y Postgres en Docker: localhost
# Si ambos corren dentro de Docker: usar el nombre del servicio (db) en vez de localhost
DB_URL=jdbc:postgresql://localhost:5432/pokemon_db
